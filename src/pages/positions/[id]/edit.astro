---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { PositionForm } from "@/components/positions/PositionForm";
import { createClient } from "@/lib/supabase";
import { getPosition, positionHasEvaluation } from "@/lib/services/positions";

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/positions");
}

const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase) {
  return Astro.redirect("/auth/signin");
}

const position = await getPosition(supabase, id);

if (!position) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const hasEvaluation = await positionHasEvaluation(supabase, id);
---

<Layout title={`Edit ${position.title} | NextChapter`}>
  <div class="mx-auto max-w-2xl px-4 py-8">
    <Topbar />
    <div class="mb-6">
      <h1 class="text-2xl font-bold">Edit Position</h1>
      <p class="text-muted-foreground mt-1 text-sm">Update the role details and requirements.</p>
    </div>
    <PositionForm mode="edit" initialData={position} hasEvaluation={hasEvaluation} client:load />
  </div>
</Layout>
