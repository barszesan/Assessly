---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { PositionForm } from "@/components/positions/PositionForm";

export const prerender = false;
---

<Layout title="New Position | NextChapter">
  <div class="mx-auto max-w-2xl px-4 py-8">
    <Topbar />
    <div class="mb-6">
      <h1 class="text-2xl font-bold">New Position</h1>
      <p class="text-muted-foreground mt-1 text-sm">Define the role requirements for candidate evaluation.</p>
    </div>
    <PositionForm mode="create" client:load />
  </div>
</Layout>
